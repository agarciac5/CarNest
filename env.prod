# .env.prod
# Copia este archivo a la VM de GCP como .env
# NUNCA lo subas a Git

POSTGRES_DB=carnest
POSTGRES_USER=carnest
POSTGRES_PASSWORD=CambiaEstaContraseña123!

# Genera una clave secreta segura con:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=reemplaza-con-clave-generada

# Ponla IP externa de tu VM de GCP aquí
# Ejemplo: 34.123.45.67
DJANGO_ALLOWED_HOSTS=TU_IP_GCP_AQUI
